CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_glinet_gl-mt3000=y

# 基础系统优化
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_KERNEL_DEBUG_INFO=n
CONFIG_DEBUG=n

# LuCI Web 管理界面
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-opkg=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# WiFi 驱动（MT7981 + MT7976C）
CONFIG_PACKAGE_kmod-mt76=y
CONFIG_PACKAGE_kmod-mt76-core=y
CONFIG_PACKAGE_kmod-mt76-connac=y
CONFIG_PACKAGE_kmod-mt76x02-common=y
CONFIG_PACKAGE_kmod-mt76x2=y
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_kmod-mt7981-firmware=y
CONFIG_PACKAGE_kmod-mt7921-common=y
CONFIG_PACKAGE_kmod-mt7921-firmware=y

# LuCI 无线菜单
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_luci-app-wifi=y

# OpenClash 主程序
CONFIG_PACKAGE_luci-app-openclash=y

# Clash Meta 内核依赖
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libcap-bin=y

# IPTV / 重庆联通组播支持
CONFIG_PACKAGE_igmpproxy=y
CONFIG_PACKAGE_luci-app-igmpproxy=y
CONFIG_PACKAGE_smcroute=y

# 系统工具
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_tar=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-base64=y

# USB 支持
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y

# 编译优化
CONFIG_DEVEL=y
CONFIG_CCACHE=y
